# Server
PORT=3010
NODE_ENV=development

# Auth0
AUTH0_DOMAIN=dev-slqw3czm8ong7s3u.us.auth0.com
AUTH0_AUDIENCE=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=venhawk

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_BUCKET_NAME=project-files

# Anthropic Claude (optional: enables tooltip reasoning for top recommendation matches)
Anthropic_API_Key=
ANTHROPIC_RECOMMENDATIONS_MODEL=claude-sonnet-4-20250514
ANTHROPIC_RECOMMENDATIONS_TIMEOUT_MS=10000
RECOMMENDATIONS_WARMUP_ON_CREATE=false
ANTHROPIC_REASONING_MODEL_PRIMARY=claude-sonnet-4-5
ANTHROPIC_REASONING_MODEL_SECONDARY=claude-haiku-4-5
ANTHROPIC_REASONING_DAILY_CAP=500

# File Upload Limits (in bytes, 0 = unlimited)
MAX_FILE_SIZE=52428800
MAX_FILES_PER_PROJECT=10
